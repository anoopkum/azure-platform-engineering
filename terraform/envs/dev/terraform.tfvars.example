# Copy this file to terraform.tfvars and fill in values.
# subscription_id is NOT stored here — it is injected at pipeline runtime
# via TF_VAR_subscription_id (GitHub secret / ADO service connection).

prefix             = "ape-dev"
env                = "dev"
location           = "uksouth"
kubernetes_version = "1.31"
system_node_count  = 2
user_node_count    = 2
tags = {
  owner       = "platform-team"
  cost_centre = "eng"
}
